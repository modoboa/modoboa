msgid "This field is required"
msgstr "Это поле обязательно для заполнения."

#: admin/api/v1/serializers.py:243
msgid ""
"List of administered domains (resellers and domain administrators only)."
msgstr "Список администрируемых доменов (только для реселлеров и администраторов доменов)."

#: admin/api/v1/serializers.py:337 admin/api/v2/serializers.py:610
msgid "Not allowed for this role."
msgstr "Недоступно для данной роли."

#: admin/api/v1/serializers.py:355
msgid "Must be equal to mailbox full_address"
msgstr "Должен совпадать с полным адресом почтового ящика."

